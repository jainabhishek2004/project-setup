CONVEX_DEPLOYMENT=dev:harmless-chinchilla-551

VITE_CONVEX_URL=https://harmless-chinchilla-551.convex.cloud

VITE_CONVEX_SITE_URL=https://harmless-chinchilla-551.convex.site

SITE_URL=http://localhost:3000
VITE_SITE_URL=http://localhost:3000

# Euler Logistics IoT API key, used by Convex actions (convex/lib/iot.ts) to
# fetch vehicle location/odometer. Set it on the Convex deployment, not here:
#   npx convex env set IOT_API_KEY <your-key>
# IOT_API_KEY=

# Optional: OSRM base URL for route optimization (convex/lib/osrm.ts). Defaults
# to the public demo server (https://router.project-osrm.org). Point it at a
# self-hosted OSRM for production:
#   npx convex env set OSRM_BASE_URL https://your-osrm-host
# OSRM_BASE_URL=
